# Public (browser-safe) — Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only — service role for trusted writes (NEVER expose to the client)
SUPABASE_SERVICE_ROLE_KEY=

# Tenant routing
NEXT_PUBLIC_ROOT_DOMAIN=earnedhome.com

# Pricing engine adapter: "stub" (default) | "graph" (Phase 1A.2)
PRICING_ADAPTER=stub

# --- Phase 1A.2: Microsoft Graph (Entra app) — not used while PRICING_ADAPTER=stub ---
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_WORKBOOK_DRIVE_ID=
GRAPH_WORKBOOK_ITEM_ID=

# Output read mode: "cells" (default — one read per output name) | "grid"
# ("grid" reads the EH_Out!eh_out_grid block in one call — needs the EH_Out tab +
#  eh_out_grid named range in the workbook first).
GRAPH_OUTPUT_MODE=cells
